generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public"]
}

enum Role {
  USER
  ADMIN

  @@schema("public")
}

model User {
  id           String               @id @default(cuid())
  username     String               @unique
  country      String?
  avatar_url   String?
  createdAt    DateTime             @default(now()) @map("created_at")
  display_name String
  updatedAt    DateTime             @updatedAt @map("updated_at")
  city         String?
  orgs         OrganizationMember[]
  ownedOrgs    Organization[]
  players      Player[]
  roles        Role[]

  @@map("users")
  @@schema("public")
}

model Organization {
  id          String               @id @default(uuid())
  name        String
  slug        String               @unique
  type        OrgType              @default(MIXED)
  createdAt   DateTime             @default(now()) @map("created_at")
  logoUrl     String?              @map("logo_url")
  ownerId     String               @map("owner_id")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  members     OrganizationMember[]
  owner       User                 @relation(fields: [ownerId], references: [id])
  teams       Team[]
  tournaments Tournament[]

  @@map("organizations")
  @@schema("public")
}

model OrganizationMember {
  id             String       @id @default(uuid())
  role           OrgRole      @default(MEMBER)
  joinedAt       DateTime     @default(now()) @map("joined_at")
  organizationId String       @map("organization_id")
  userId         String       @map("user_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
  @@schema("public")
}

model Game {
  id          String       @id @default(uuid())
  name        String
  logoUrl     String?      @map("logo_url")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  tournaments Tournament[]

  @@map("games")
  @@schema("public")
}

model Team {
  id             String                   @id @default(uuid())
  name           String
  slug           String
  createdAt      DateTime                 @default(now()) @map("created_at")
  logoUrl        String?                  @map("logo_url")
  organizationId String                   @map("organization_id")
  updatedAt      DateTime                 @updatedAt @map("updated_at")
  awayMatches    Match[]                  @relation("AwayTeam")
  homeMatches    Match[]                  @relation("HomeTeam")
  players        Player[]
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  registrations  TournamentRegistration[]

  @@unique([organizationId, slug])
  @@map("teams")
  @@schema("public")
}

model Player {
  id        String   @id @default(uuid())
  nickname  String
  role      String?
  number    Int?
  createdAt DateTime @default(now()) @map("created_at")
  isActive  Boolean  @default(true) @map("is_active")
  teamId    String   @map("team_id")
  userId    String?  @map("user_id")
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])

  @@map("players")
  @@schema("public")
}

model Tournament {
  id             String                   @id @default(uuid())
  name           String
  slug           String
  description    String?
  status         TournamentStatus         @default(DRAFT)
  bannerUrl      String?                  @map("banner_url")
  createdAt      DateTime                 @default(now()) @map("created_at")
  endDate        DateTime?                @map("end_date")
  isPublic       Boolean                  @default(true) @map("is_public")
  maxTeams       Int?                     @map("max_teams")
  organizationId String                   @map("organization_id")
  startDate      DateTime?                @map("start_date")
  updatedAt      DateTime                 @updatedAt @map("updated_at")
  gameId         String                   @map("game_id")
  phases         Phase[]
  pitches        Pitch[]
  registrations  TournamentRegistration[]
  game           Game                     @relation(fields: [gameId], references: [id])
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@map("tournaments")
  @@schema("public")
}

model TournamentRegistration {
  id           String     @id @default(uuid())
  seed         Int?
  isConfirmed  Boolean    @default(false) @map("is_confirmed")
  registeredAt DateTime   @default(now()) @map("registered_at")
  teamId       String     @map("team_id")
  tournamentId String     @map("tournament_id")
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, teamId])
  @@map("tournament_registrations")
  @@schema("public")
}

model Pitch {
  id           String     @id @default(uuid())
  name         String
  tournamentId String     @map("tournament_id")
  phaseId      String?
  matches      Match[]
  phase        Phase?     @relation(fields: [phaseId], references: [id])
  tournament   Tournament @relation(fields: [tournamentId], references: [id])

  @@map("pitches")
  @@schema("public")
}

model Phase {
  id           String     @id @default(uuid())
  name         String
  type         PhaseType
  order        Int
  config       Json?
  createdAt    DateTime   @default(now()) @map("created_at")
  isCompleted  Boolean    @default(false) @map("is_completed")
  tournamentId String     @map("tournament_id")
  matches      Match[]
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  pitches      Pitch[]

  @@map("phases")
  @@schema("public")
}

model Match {
  id          String       @id @default(uuid())
  status      MatchStatus  @default(SCHEDULED)
  awayTeamId  String?      @map("away_team_id")
  bracketPos  String?      @map("bracket_pos")
  createdAt   DateTime     @default(now()) @map("created_at")
  homeTeamId  String?      @map("home_team_id")
  phaseId     String       @map("phase_id")
  playedAt    DateTime?    @map("played_at")
  roundNumber Int?         @map("round_number")
  scheduledAt DateTime?    @map("scheduled_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  pitchId     String       @map("pitch_id")
  result      MatchResult?
  awayTeam    Team?        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeTeam    Team?        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  phase       Phase        @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  pitch       Pitch        @relation(fields: [pitchId], references: [id], onDelete: Cascade)

  @@map("matches")
  @@schema("public")
}

model MatchResult {
  id           String   @id @default(uuid())
  notes        String?
  awayScore    Int      @map("away_score")
  homeScore    Int      @map("home_score")
  matchId      String   @unique @map("match_id")
  recordedAt   DateTime @default(now()) @map("recorded_at")
  recordedById String?  @map("recorded_by_id")
  winnerId     String?  @map("winner_id")
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@map("match_results")
  @@schema("public")
}

enum OrgType {
  SPORT
  ESPORT
  MIXED

  @@schema("public")
}

enum OrgRole {
  OWNER
  ADMIN
  MODERATOR
  MEMBER

  @@schema("public")
}

enum TournamentStatus {
  DRAFT
  REGISTRATION
  ONGOING
  FINISHED
  CANCELLED

  @@schema("public")
}

enum PhaseType {
  GROUP
  BRACKET_SINGLE
  BRACKET_DOUBLE
  ROUND_SWISS
  CUSTOM

  @@schema("public")
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  CANCELLED

  @@schema("public")
}

// Admin

enum NavigationContext {
  ADMIN_SaaS // Pour le dashboard de l'admin global
  USER_DASHBOARD // Pour le dashboard global
  ORGANIZATION // Pour une sidebar liée qu'à l'organisation

  @@schema("public")
}

model NavigationItem {
  id       String            @id @default(uuid())
  name     String
  label    String
  href     String
  icon     String?
  order    Int               @default(0)
  isActive Boolean           @default(true)
  context  NavigationContext @default(USER_DASHBOARD)

  parentId String?
  parent   NavigationItem?  @relation("SubItems", fields: [parentId], references: [id])
  children NavigationItem[] @relation("SubItems")

  requiredRole String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- LES AJOUTS ICI ---
  @@unique([name, context]) // Permet l'upsert via name_context
  @@map("admin__navigation_items")
  @@schema("public")
}
